# Integration test configuration for plugin-asterisk.
# Copy this file to .env.integration and fill in your values.
# Never commit .env.integration — it is listed in .gitignore.
#
# Load before running integration tests:
#   source .env.integration
#   go test -tags integration -v ./app/...

ASTERISK_ARI_URL=http://<host>:8088
ASTERISK_ARI_USER=<username>
ASTERISK_ARI_PASS=<password>
